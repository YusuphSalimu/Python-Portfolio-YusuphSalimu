{
  "name": "dopefolio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npx --yes serve .",
    "compile:scss": "npx --yes sass sass/main.scss css/style.css --watch",
    "prefix:css": "npx --yes postcss css/style.css --use autoprefixer -o css/style.css",
    "compress:css": "npx --yes sass css/style.css css/style.css --style=compressed",
    "build": "npm-run-all prefix:css compress:css"
  },
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.1",
    "sass": "^1.86.3",
    "serve": "^14.2.4"
  }
}
